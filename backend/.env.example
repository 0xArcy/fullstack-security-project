PORT=3000
NODE_ENV=production
TRUST_PROXY=1
COOKIE_SECURE=true
MONGO_URI=mongodb://<db_user>:<db_password>@<db_host>:27017/secure_db?authSource=admin&tls=true
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_TLS_CA_FILE=
MONGO_TLS_ALLOW_INVALID_CERTS=false
JWT_SECRET=<64_hex_chars>
JWT_REFRESH_SECRET=<64_hex_chars>
FIELD_ENCRYPT_KEY=<64_hex_chars>
ALLOWED_ORIGIN=https://<frontend-domain-or-ip>
